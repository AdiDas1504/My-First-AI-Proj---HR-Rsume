# Copy this file to .env and fill in your values.
# Never commit .env to GitHub.

# ── Claude AI (optional) ──────────────────────────────────────────────────────
# The app runs fully without these. AI features activate only when a key is set
# and the user gives explicit in-app consent.

ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ── Supabase database (optional) ─────────────────────────────────────────────
# The app runs fully without these. Database features are silently disabled
# when these are not set. Find these values in your Supabase project settings
# under Project Settings > API.

SUPABASE_URL=
SUPABASE_ANON_KEY=
